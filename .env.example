# ─────────────────────────────────────────────
#  Savera Kirana API — Environment variables
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
REMOTE_BASE_URL=http://localhost:4000

# MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017/savera-kirana

# JWT
JWT_SECRET=asldkfjs898difu9s8dfsldfjsaveralsdkirana
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_MINUTES=43200
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Super Admin seeder (used by npm run seed:super-admin)
SUPER_ADMIN_NAME=Piyush
SUPER_ADMIN_EMAIL=piyush@sdlccorp.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_PHONE=+919999999999

# Twilio (OTP for customer login) — optional, dev prints OTP to console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=

# Razorpay (customer payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary (FREE image hosting — 25 GB/mo — used for product/banner images)
# Sign up: https://cloudinary.com  →  Dashboard shows these 3 values
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=savera-kirana

# AWS S3 (kept optional — leave empty to disable)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Google OAuth (customer social login — optional)
CLIENT_ID=
CLIENT_SECRET=

# CORS allowlist (comma-separated) — leave blank to allow all in dev
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
